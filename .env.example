# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=kui_db

# Redis 配置（预留）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Flask 配置
SECRET_KEY=your-secret-key-change-me
FLASK_ENV=production
FLASK_DEBUG=0

# B站Cookie（默认fallback）
BILIBILI_COOKIE=your-bilibili-cookie-here

# 邮件配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SENDER_EMAIL=your-email@qq.com
SENDER_PASSWORD=your-email-auth-code

# 字体路径（Linux）
FONT_PATH=/usr/share/fonts/truetype/simhei.ttf
